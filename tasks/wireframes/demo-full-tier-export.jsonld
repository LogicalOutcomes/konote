    {
      "@id": "urn:konote:stakeholder:5-0",
      "@type": "cids:Stakeholder",
      "cids:hasName": "Youth aged 16-24, unemployed",
      "cids:hasDescription": "Unemployed youth in the Greater Toronto Area, including those with no prior work experience and those who have been laid off.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },
    {
      "@id": "urn:konote:stakeholder:5-1",
      "@type": "cids:Stakeholder",
      "cids:hasName": "Newcomer youth (arrived <5 years)",
      "cids:hasDescription": "Youth who immigrated to Canada within the last 5 years and face additional barriers including language, credential recognition, and limited professional networks.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },

    {
      "@id": "urn:konote:stakeholder-outcome:5",
      "@type": "cids:StakeholderOutcome",
      "cids:hasName": "Aggregate outcomes: Bright Futures Youth Employment Services",
      "cids:hasDescription": "Of 23 participant targets: 15 achieved/sustaining, 5 in progress/improving, 3 no change.",
      "cids:forOutcome": {"@id": "urn:konote:program-outcome:5"},
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },

    {
      "@id": "urn:konote:service:201",
      "@type": "cids:Service",
      "cids:hasName": "Job Readiness Training (12 weeks)",
      "cids:hasDescription": "Structured 12-week program combining group skills workshops, individual mentorship, and supported job search. Delivered in cohorts of 20, three intake periods per year."
    },
    {
      "@id": "urn:konote:activity:301",
      "@type": "cids:Activity",
      "cids:hasName": "Group skills workshops (3x/week)",
      "cids:hasDescription": "Three 2-hour facilitated workshops per week covering resume writing, interview preparation, workplace communication, digital literacy, and financial literacy."
    },
    {
      "@id": "urn:konote:activity:302",
      "@type": "cids:Activity",
      "cids:hasName": "1:1 mentorship sessions (weekly)",
      "cids:hasDescription": "Weekly 45-minute sessions pairing each participant with a volunteer mentor in the participant's field of interest."
    },

    {
      "@id": "urn:konote:output:5-sessions",
      "@type": "cids:Output",
      "cids:hasName": "Training sessions delivered",
      "cids:hasDescription": "342 sessions delivered (216 group workshops + 126 mentorship meetings). Average 14.9 per participant against a target of 12 minimum.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },
    {
      "@id": "urn:konote:output:5-placements",
      "@type": "cids:Output",
      "cids:hasName": "Job placements achieved",
      "cids:hasDescription": "18 of 23 participants placed in employment within 90 days of program completion. 12 full-time, 6 part-time.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },

    {
      "@id": "urn:konote:impact-risk:101",
      "@type": "cids:ImpactRisk",
      "cids:hasName": "Economic downturn reduces available positions",
      "cids:hasDescription": "A recession could reduce entry-level positions, making placement harder despite participant readiness.",
      "cids:hasLikelihood": "medium",
      "cids:hasSeverity": "high",
      "cids:hasMitigation": "Diversify employer partnerships across sectors (12 partners in retail, hospitality, tech, healthcare, nonprofit). Maintain relationships with social enterprises."
    },
    {
      "@id": "urn:konote:impact-risk:102",
      "@type": "cids:ImpactRisk",
      "cids:hasName": "Participant attrition due to housing instability",
      "cids:hasDescription": "Youth experiencing housing instability may not maintain consistent attendance in the 12-week program.",
      "cids:hasLikelihood": "medium",
      "cids:hasSeverity": "medium",
      "cids:hasMitigation": "Partner with 3 local shelters for transit passes and flexible scheduling. Offer hybrid attendance for participants in precarious housing."
    },

    {
      "@id": "urn:konote:counterfactual:401",
      "@type": "cids:Counterfactual",
      "cids:hasName": "Baseline: Employment Ontario services only",
      "cids:hasDescription": "Without the program, participants would access basic Employment Ontario services (job boards, resume review) but not structured training or mentorship. Comparable GTA youth programs show 23% placement without structured support, vs. our 78%."
    },

