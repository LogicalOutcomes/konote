    {
      "@id": "urn:konote:indicator-report:5:12",
      "@type": "cids:IndicatorReport",
      "hasName": "Employment Status — September 2025 cohort",
      "forOrganization": {"@id": "urn:konote:org:1"},
      "forIndicator": {"@id": "urn:konote:indicator:5:12"},
      "startedAtTime": "2025-09-15T00:00:00-04:00",
      "endedAtTime": "2026-03-01T00:00:00-05:00",
      "value": {
        "@type": "i72:Measure",
        "hasNumericalValue": "78",
        "hasUnit": "percent"
      },
      "hasComment": "18 of 23 participants achieved employment (full-time or part-time). Breakdown: 12 full-time, 6 part-time, 3 in training, 2 still seeking. Success rate: 78% (target: 65%).",
      "hasBaseline": "23% placement rate (Employment Ontario services alone, 2024 GTA youth cohort comparison)"
    },
    {
      "@id": "urn:konote:indicator-report:5:13",
      "@type": "cids:IndicatorReport",
      "hasName": "Job Readiness Score — September 2025 cohort",
      "forOrganization": {"@id": "urn:konote:org:1"},
      "forIndicator": {"@id": "urn:konote:indicator:5:13"},
      "startedAtTime": "2025-09-22T00:00:00-04:00",
      "endedAtTime": "2026-02-28T00:00:00-05:00",
      "value": {
        "@type": "i72:Measure",
        "hasNumericalValue": "7.8",
        "hasUnit": "score (1-10 scale)"
      },
      "hasComment": "Mean score improved from 3.2 (intake) to 7.8 (program end). 23 participants measured at intake and at 4-week intervals. 20 of 23 (87%) moved from low band (1-4) to high band (7-10). Scores suppressed where cohort subgroup < 5.",
      "hasBaseline": "3.2 (mean intake score, n=23)"
    },
