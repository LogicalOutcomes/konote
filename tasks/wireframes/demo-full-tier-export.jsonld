    {
      "@id": "urn:konote:program-outcome:5",
      "@type": "cids:Outcome",
      "hasName": "Bright Futures Youth Employment Services outcomes",
      "hasDescription": "Comprehensive employment readiness program for youth aged 16-24 in the Greater Toronto Area. Provides job skills training, mentorship, and placement support to help young people achieve sustainable employment.",
      "forOrganization": {"@id": "urn:konote:org:1"},
      "hasIndicator": [
        {"@id": "urn:konote:indicator:5:12"},
        {"@id": "urn:konote:indicator:5:13"},
        {"@id": "urn:konote:indicator:5:14"},
        {"@id": "urn:konote:indicator:5:15"}
      ],
      "forTheme": [
        {"@id": "urn:konote:theme:employment"},
        {"@id": "urn:konote:theme:education-and-training"}
      ]
    },
    {
      "@id": "urn:konote:impact-model:5",
      "@type": "cids:ImpactModel",
      "cids:hasName": "Impact Model: Bright Futures Youth Employment Services",
      "cids:hasDescription": "Youth aged 16-24 who are unemployed or underemployed participate in a 12-week job readiness program. Through skills training (weeks 1-6), mentorship matching (weeks 4-8), and supported job search (weeks 8-12), participants develop employment competencies. Expected chain: Training \u2192 Skills acquisition \u2192 Confidence \u2192 Job interviews \u2192 Employment \u2192 Income stability.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"},
      "cids:hasOutcome": [{"@id": "urn:konote:program-outcome:5"}],
      "cids:hasIndicator": [
        {"@id": "urn:konote:indicator:5:12"},
        {"@id": "urn:konote:indicator:5:13"},
        {"@id": "urn:konote:indicator:5:14"},
        {"@id": "urn:konote:indicator:5:15"}
      ],
      "cids:hasStakeholder": [
        {"@id": "urn:konote:stakeholder:5-0"},
        {"@id": "urn:konote:stakeholder:5-1"},
        {"@id": "urn:konote:stakeholder:5-2"}
      ],
      "cids:hasStakeholderOutcome": [{"@id": "urn:konote:stakeholder-outcome:5"}],
      "cids:hasOutput": [
        {"@id": "urn:konote:output:5-14"},
        {"@id": "urn:konote:output:5-placement"}
      ],
      "cids:hasImpactRisk": [
        {"@id": "urn:konote:impact-risk:101"},
        {"@id": "urn:konote:impact-risk:102"}
      ],
      "cids:hasService": [{"@id": "urn:konote:service:201"}],
      "cids:hasActivity": [
        {"@id": "urn:konote:activity:301"},
        {"@id": "urn:konote:activity:302"}
      ],
      "cids:hasCounterfactual": [{"@id": "urn:konote:counterfactual:401"}]
    },
    {
      "@id": "urn:konote:stakeholder:5-0",
      "@type": "cids:Stakeholder",
      "cids:hasName": "Youth aged 16-24, unemployed",
      "cids:hasDescription": "Unemployed youth in the Greater Toronto Area aged 16-24, including those with no prior work experience and those who have been laid off.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"},
      "cids:hasDemographic": "Age 16-24, unemployed or underemployed",
      "cids:hasSize": 20
    },
    {
      "@id": "urn:konote:stakeholder:5-1",
      "@type": "cids:Stakeholder",
      "cids:hasName": "Newcomer youth (arrived <5 years)",
      "cids:hasDescription": "Youth who immigrated to Canada within the last 5 years and face additional barriers including language, credential recognition, and limited professional networks.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"},
      "cids:hasDemographic": "Newcomer youth, arrived within 5 years",
      "cids:hasSize": 8
    },
    {
      "@id": "urn:konote:stakeholder:5-2",
      "@type": "cids:Stakeholder",
      "cids:hasName": "Indigenous youth",
      "cids:hasDescription": "Indigenous youth participants who may face systemic barriers to employment.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"},
      "cids:hasDemographic": "First Nations, Inuit, or M\u00e9tis youth",
      "cids:hasSize": 3
    },
    {
      "@id": "urn:konote:stakeholder-outcome:5",
      "@type": "cids:StakeholderOutcome",
      "cids:hasName": "Aggregate outcomes: Bright Futures Youth Employment Services",
      "cids:hasDescription": "Of 23 participant targets: 15 achieved/sustaining, 5 in progress/improving, 3 no change.",
      "cids:forOutcome": {"@id": "urn:konote:program-outcome:5"},
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },
    {
      "@id": "urn:konote:service:201",
      "@type": "cids:Service",
      "cids:hasName": "Job Readiness Training (12 weeks)",
      "cids:hasDescription": "Structured 12-week program combining group skills workshops, individual mentorship, and supported job search. Delivered in cohorts of 20 participants, three intake periods per year (September, January, April)."
    },
    {
      "@id": "urn:konote:activity:301",
      "@type": "cids:Activity",
      "cids:hasName": "Group skills workshops (3x/week)",
      "cids:hasDescription": "Three 2-hour facilitated workshops per week covering resume writing, interview preparation, workplace communication, digital literacy, and financial literacy. Delivered in-person at the GTA Community Centre."
    },
    {
      "@id": "urn:konote:activity:302",
      "@type": "cids:Activity",
      "cids:hasName": "1:1 mentorship sessions (weekly)",
      "cids:hasDescription": "Weekly 45-minute mentorship sessions pairing each participant with a volunteer mentor who has employment experience in the participant's field of interest. Mentors provide coaching, networking support, and accountability."
    },
    {
      "@id": "urn:konote:output:5-14",
      "@type": "cids:Output",
      "cids:hasName": "Observations: Sessions Attended",
      "cids:hasDescription": "342 recorded observations for Sessions Attended in Bright Futures Youth Employment Services.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },
    {
      "@id": "urn:konote:output:5-placement",
      "@type": "cids:Output",
      "cids:hasName": "Job placements achieved",
      "cids:hasDescription": "18 job placements achieved within 90 days of program completion for the September 2025 cohort. Target was 15-18 placements per cohort of 20.",
      "cids:forOrganization": {"@id": "urn:konote:org:1"}
    },
    {
      "@id": "urn:konote:impact-risk:101",
      "@type": "cids:ImpactRisk",
      "cids:hasName": "Economic downturn reduces available positions",
      "cids:hasDescription": "An economic recession or sector-specific downturn could reduce the number of available entry-level positions, making job placement more difficult despite participant readiness.",
      "cids:hasLikelihood": "medium",
      "cids:hasSeverity": "high",
      "cids:hasMitigation": "Diversify employer partnerships across sectors (currently 12 employer partners in retail, hospitality, tech, healthcare, and nonprofit). Maintain relationships with social enterprises willing to create positions."
    },
    {
      "@id": "urn:konote:impact-risk:102",
      "@type": "cids:ImpactRisk",
      "cids:hasName": "Participant attrition due to housing instability",
      "cids:hasDescription": "Youth experiencing housing instability may be unable to maintain consistent attendance in the 12-week program, reducing program completion rates.",
      "cids:hasLikelihood": "medium",
      "cids:hasSeverity": "medium",
      "cids:hasMitigation": "Partner with 3 local shelters to provide transit passes and flexible scheduling. Offer hybrid attendance (in-person + virtual) for participants in precarious housing situations."
    },
    {
      "@id": "urn:konote:counterfactual:401",
      "@type": "cids:Counterfactual",
      "cids:hasName": "Baseline: Employment Ontario services only",
      "cids:hasDescription": "Without the Bright Futures program, participants would access basic Employment Ontario services (job boards, resume review) but not structured training or mentorship. Comparable youth employment programs in the GTA show a 23% placement rate without structured support, compared to our target of 65% and actual rate of 78% for the September 2025 cohort."
    },
    {
      "@id": "urn:konote:org:1",
      "@type": "cids:Organization",
      "hasLegalName": "Bright Futures Community Services",
      "hasName": "Bright Futures",
      "hasDescription": "A Toronto-based nonprofit providing employment, education, and settlement services to youth and newcomers since 2008.",
      "hasAddress": [{"@id": "urn:konote:address:1"}],
      "hasOutcome": [{"@id": "urn:konote:program-outcome:5"}],
