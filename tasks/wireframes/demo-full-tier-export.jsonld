      "value": {
        "@type": "i72:Measure",
        "hasNumericalValue": "342",
        "hasUnit": "sessions"
      },
      "hasComment": "342 total sessions across 23 participants (avg 14.9 per participant). Program target: 12 sessions minimum. 19 of 23 (83%) met the minimum attendance threshold. Includes 216 group workshops and 126 mentorship meetings."
    },
    {
      "@id": "urn:konote:indicator-report:5:15",
      "@type": "cids:IndicatorReport",
      "hasName": "Employment Retention (90-day) — September 2025 cohort",
