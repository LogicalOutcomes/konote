      "value": {
        "@type": "i72:Measure",
        "hasNumericalValue": "83",
        "hasUnit": "percent"
      },
      "hasComment": "Of the 18 participants who achieved employment, 15 (83%) maintained it for 90+ days. 2 changed employers but remained employed. 1 returned to training. Measurement ongoing for 3 participants who were placed after January 2026."
    },

